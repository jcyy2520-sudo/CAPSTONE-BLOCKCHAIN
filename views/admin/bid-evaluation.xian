{{> head }}
<body class="bg-gray-50 min-h-screen flex">

  <!-- Sidebar -->
  {{> sidebar }}

  <!-- Main Content -->
  <main class="flex-1 ml-56">
    <!-- Top Header -->
    <header class="bg-white border-b border-gray-100 px-6 py-3 flex items-center justify-between">
      <nav class="flex items-center gap-6">
        <a href="/admin/dashboard" class="text-sm text-gray-400 hover:text-gray-800">ProcureChain</a>
        <a href="/admin/dashboard" class="text-sm text-gray-400 hover:text-gray-800">Projects</a>
        <a href="/admin/bid-evaluation" class="text-sm text-primary font-semibold border-b-2 border-primary pb-0.5">Evaluations</a>
        <a href="/admin/final-ranking" class="text-sm text-gray-400 hover:text-gray-800">Reports</a>
        <a href="/admin/smart-contract" class="text-sm text-gray-400 hover:text-gray-800">Settings</a>
      </nav>
      <div class="flex items-center gap-3">
        <div class="relative"><i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-300 text-sm"></i><input type="text" placeholder="Search bids..." class="pl-9 pr-4 py-2 border border-gray-200 rounded-lg text-sm w-48 focus:outline-none focus:ring-2 focus:ring-primary/20"></div>
        <button class="relative w-8 h-8 text-gray-400"><i class="fas fa-bell text-sm"></i><span class="absolute -top-0.5 -right-0.5 w-3 h-3 bg-red-500 rounded-full"></span></button>
        <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center"><i class="fas fa-user text-primary text-sm"></i></div>
      </div>
    </header>

    <div class="p-8">
      <!-- Breadcrumb & Title -->
      <div class="text-xs text-gray-400 mb-1"><a href="/admin/dashboard" class="hover:text-primary">Projects</a> > <span class="text-gray-600">BAC-2023-001</span></div>
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl font-extrabold text-gray-900">Bid Evaluation</h1>
          <p class="text-sm text-gray-400 mt-1">Comparing technical and financial proposals for Sewer Rehab Project.</p>
        </div>
        <div class="bg-white rounded-xl card-shadow p-4 min-w-[180px]">
          <div class="flex items-center justify-between mb-1"><span class="text-xs font-semibold text-gray-600">Overall Progress</span><span class="text-xs font-bold text-success-green">75%</span></div>
          <div class="w-full bg-gray-100 rounded-full h-2"><div class="bg-primary rounded-full h-2" style="width:75%"></div></div>
          <p class="text-[10px] text-gray-400 mt-1">3 of 4 bidders evaluated</p>
        </div>
      </div>

      <!-- Participating Bidders -->
      <div class="bg-white rounded-xl card-shadow p-6 mb-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-base font-bold text-gray-900">Participating Bidders</h2>
          <div class="flex items-center gap-2">
            <button class="px-3 py-1.5 border border-gray-200 text-xs text-gray-500 rounded-lg hover:bg-gray-50 flex items-center gap-1"><i class="fas fa-filter text-[10px]"></i> Filter</button>
            <button class="px-3 py-1.5 border border-gray-200 text-xs text-gray-500 rounded-lg hover:bg-gray-50 flex items-center gap-1"><i class="fas fa-download text-[10px]"></i> Export</button>
          </div>
        </div>
        <table class="w-full text-sm">
          <thead><tr class="border-b border-gray-100">
            <th class="text-left pb-3 text-[10px] font-semibold text-primary uppercase tracking-wider">Bidder Details</th>
            <th class="text-center pb-3 text-[10px] font-semibold text-primary uppercase tracking-wider">Technical Proposal</th>
            <th class="text-center pb-3 text-[10px] font-semibold text-primary uppercase tracking-wider">Financial Proposal</th>
            <th class="text-center pb-3 text-[10px] font-semibold text-primary uppercase tracking-wider">Blockchain Sync</th>
            <th class="text-center pb-3 text-[10px] font-semibold text-primary uppercase tracking-wider">Actions</th>
          </tr></thead>
          <tbody>
            <tr class="border-b border-gray-50">
              <td class="py-4"><div class="font-semibold text-gray-900">Urban Infra Solutions</div><div class="text-[10px] text-gray-400">ID: UI-2023-99</div></td>
              <td class="py-4 text-center"><span class="px-2 py-0.5 bg-green-50 text-success-green text-[10px] font-bold rounded-full">Verified</span></td>
              <td class="py-4 text-center"><span class="px-2 py-0.5 bg-yellow-50 text-yellow-600 text-[10px] font-bold rounded-full flex items-center gap-1 justify-center"><i class="fas fa-lock-open text-[8px]"></i>Unlocked</span></td>
              <td class="py-4 text-center"><span class="text-xs font-mono text-primary">0x71c...8a27</span></td>
              <td class="py-4 text-center"><a href="/admin/bid-scoring" class="px-3 py-1.5 bg-primary text-white text-xs font-semibold rounded-lg hover:bg-primary-dark">Review</a></td>
            </tr>
            <tr class="border-b border-gray-50">
              <td class="py-4"><div class="font-semibold text-gray-900">Global Pipes Co.</div><div class="text-[10px] text-gray-400">ID: GP-2023-41</div></td>
              <td class="py-4 text-center"><span class="px-2 py-0.5 bg-yellow-50 text-yellow-600 text-[10px] font-bold rounded-full">Scored</span></td>
              <td class="py-4 text-center"><span class="px-2 py-0.5 bg-yellow-50 text-yellow-600 text-[10px] font-bold rounded-full flex items-center gap-1 justify-center"><i class="fas fa-lock-open text-[8px]"></i>Unlocked</span></td>
              <td class="py-4 text-center"><span class="text-xs font-mono text-primary">0x92h...4b11</span></td>
              <td class="py-4 text-center"><a href="/admin/bid-scoring" class="px-3 py-1.5 bg-primary text-white text-xs font-semibold rounded-lg hover:bg-primary-dark">Review</a></td>
            </tr>
            <tr class="border-b border-gray-50">
              <td class="py-4"><div class="font-semibold text-gray-900">Metro Builders</div><div class="text-[10px] text-gray-400">ID: MB-2023-02</div></td>
              <td class="py-4 text-center"><span class="px-2 py-0.5 bg-green-50 text-success-green text-[10px] font-bold rounded-full">Verified</span></td>
              <td class="py-4 text-center"><span class="px-2 py-0.5 bg-gray-100 text-gray-500 text-[10px] font-bold rounded-full flex items-center gap-1 justify-center"><i class="fas fa-lock text-[8px]"></i>Locked</span></td>
              <td class="py-4 text-center"><span class="text-xs font-mono text-primary">0x1a...3c9d</span></td>
              <td class="py-4 text-center"><a href="/admin/bid-scoring" class="px-3 py-1.5 bg-primary text-white text-xs font-semibold rounded-lg hover:bg-primary-dark">Review</a></td>
            </tr>
            <tr>
              <td class="py-4"><div class="font-semibold text-gray-900">Riverside Tech</div><div class="text-[10px] text-gray-400">ID: RT-2023-88</div></td>
              <td class="py-4 text-center"><span class="px-2 py-0.5 bg-yellow-50 text-yellow-600 text-[10px] font-bold rounded-full flex items-center gap-1 justify-center"><span class="w-1.5 h-1.5 bg-yellow-500 rounded-full"></span>Pending</span></td>
              <td class="py-4 text-center"><span class="px-2 py-0.5 bg-gray-100 text-gray-500 text-[10px] font-bold rounded-full flex items-center gap-1 justify-center"><i class="fas fa-lock text-[8px]"></i>Locked</span></td>
              <td class="py-4 text-center"><span class="text-xs text-gray-400 italic">Pending Sync</span></td>
              <td class="py-4 text-center"><a href="/admin/bid-scoring" class="px-3 py-1.5 bg-primary text-white text-xs font-semibold rounded-lg hover:bg-primary-dark">Review</a></td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Warning & Submit -->
      <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 mb-6">
        <div class="flex items-center gap-3">
          <i class="fas fa-exclamation-triangle text-yellow-500"></i>
          <div class="flex-1"><strong class="text-xs text-gray-700">Pending Evaluation:</strong><span class="text-xs text-gray-500"> Final ranking submission will be enabled once technical and financial status for all bidders has been finalized and blockchain verified.</span></div>
          <button class="px-4 py-2 border border-gray-300 text-gray-600 text-xs font-bold rounded-lg flex items-center gap-2 whitespace-nowrap"><i class="fas fa-paper-plane text-[10px]"></i> SUBMIT FINAL RANKING</button>
        </div>
      </div>

      <!-- Bottom Stats -->
      <div class="grid grid-cols-3 gap-4">
        <div class="bg-white rounded-xl card-shadow p-5 flex items-center gap-4">
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center"><i class="fas fa-wallet text-primary text-xl"></i></div>
          <div><div class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Budget Allocation</div><div class="text-xl font-extrabold text-gray-900">₱24.5M</div></div>
        </div>
        <div class="bg-white rounded-xl card-shadow p-5 flex items-center gap-4">
          <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center"><i class="fas fa-shield-halved text-success-green text-xl"></i></div>
          <div><div class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Security Level</div><div class="text-xl font-extrabold text-gray-900">Blockchain (Layer 2)</div></div>
        </div>
        <div class="bg-white rounded-xl card-shadow p-5 flex items-center gap-4">
          <div class="w-12 h-12 bg-orange-50 rounded-xl flex items-center justify-center"><i class="fas fa-clock text-orange-500 text-xl"></i></div>
          <div><div class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Days Remaining</div><div class="text-xl font-extrabold text-gray-900">4 Days</div></div>
        </div>
      </div>
    </div>
  </main>
</body>
</html>